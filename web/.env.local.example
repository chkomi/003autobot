# ── 로컬 개발용 환경변수 템플릿 ──────────────────────────────
# 복사: cp .env.local.example .env.local
# .env.local 은 .gitignore에 포함되어야 합니다 (비밀키 노출 방지)

# FastAPI 서버 URL
# 로컬 개발: http://localhost:8080
# Cloudflare Tunnel: https://your-tunnel-url.trycloudflare.com
AUTOBOT_API_URL=http://localhost:8080

# API 인증 키 (api/config.py AUTOBOT_API_API_KEY 와 동일)
# 로컬 개발 시 비워두면 인증 비활성화됨
AUTOBOT_API_KEY=
