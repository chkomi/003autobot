# ============================================================
# OKX API Credentials
# OKX 데모 계정에서 별도 API 키 발급 필요: okx.com → 데모 거래 → API
# ============================================================
#
# [보안 권장]
# - 이 파일을 실제 키 값으로 채운 뒤 반드시 파일명을 `.env` 로 저장하고
#   `chmod 600 .env` 를 설정할 것 (settings.load_settings 가 권한을 점검함)
# - OKX API 키는 "거래(Trade)"만 허용하고 "출금(Withdraw)"은 반드시 차단할 것
# - 가능하면 IP 화이트리스트도 설정할 것
# - .env 파일을 깃에 커밋하지 말 것 (.gitignore 확인)
# - 주기적으로(최소 분기 1회) 키를 재발급(순환)할 것
#
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# true = 페이퍼 트레이딩 (반드시 true로 시작!)
OKX_IS_DEMO=true

# ============================================================
# Trading Parameters
# ============================================================
TRADING_SYMBOL=BTC/USDT:USDT
# 멀티 심볼 거래 (쉼표 구분). 설정 시 TRADING_SYMBOL보다 우선
TRADING_SYMBOLS=BTC/USDT:USDT,GMT/USDT:USDT,SUI/USDT:USDT
TRADING_LEVERAGE=5
TRADING_MAX_POSITION_PCT=0.10
TRADING_MAX_OPEN_POSITIONS=3

# ============================================================
# Risk Management
# ============================================================
RISK_DAILY_LOSS_LIMIT_PCT=0.03
RISK_WEEKLY_LOSS_LIMIT_PCT=0.08
RISK_MAX_DRAWDOWN_PCT=0.15
RISK_KELLY_FRACTION=0.25

# ============================================================
# [고도화] 뉴스 감시 (news_collector.py)
# - 기본 무료 RSS(CoinDesk/Cointelegraph/Bitcoin Magazine)는 키 없이 동작
# - CryptoPanic 프리 티어 키를 넣으면 Hot Posts 피드가 추가됨
#   발급: https://cryptopanic.com/developers/api/
# ============================================================
CRYPTOPANIC_API_KEY=

# ============================================================
# Telegram Notifications
# BotFather에서 봇 생성 후 토큰 발급, 채팅 ID 확인
# ============================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================================
# Discord Notifications (Webhook)
# 서버 설정 → 연동 → 웹후크 만들기 → URL 복사
# ============================================================
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# ============================================================
# System
# ============================================================
LOG_LEVEL=INFO
DB_PATH=data_cache/trading.db
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# ── API 서비스 (plan v2 §3.2) ────────────────────────────────
# PostgreSQL (docker-compose 기본값)
AUTOBOT_API_DATABASE_URL=postgresql+asyncpg://autobot:autobot@localhost:5432/autobot

# Redis (docker-compose 기본값)
AUTOBOT_API_REDIS_URL=redis://localhost:6379/0

# CORS (Next.js 개발 서버)
AUTOBOT_API_CORS_ALLOW_ORIGINS=http://localhost:3000

# 환경 (dev | staging | prod)
AUTOBOT_API_ENV=dev
